cmake_minimum_required(VERSION 3.22)
project(__PLUGIN_NAME__ VERSION 1.0.0)

# JUCE SDK path passed from workflow via -DJUCE_SOURCE_DIR
if(NOT DEFINED JUCE_SOURCE_DIR)
    message(FATAL_ERROR "JUCE_SOURCE_DIR must be set (e.g., -DJUCE_SOURCE_DIR=~/juce-sdk)")
endif()

add_subdirectory(${JUCE_SOURCE_DIR} juce_sdk EXCLUDE_FROM_ALL)

# Embed HTML/CSS/JS UI files as binary data (compiled into plugin binary)
juce_add_binary_data(PluginUIData
    HEADER_NAME BinaryData.h
    NAMESPACE BinaryData
    SOURCES
        __BINARY_DATA_FILES__
)

# Define the plugin
juce_add_plugin(__PLUGIN_NAME__
    COMPANY_NAME           "Catalvst"
    PLUGIN_MANUFACTURER_CODE Cvst
    PLUGIN_CODE            __PLUGIN_CODE__
    FORMATS                VST3 AU Standalone
    PRODUCT_NAME           "__PLUGIN_NAME__"
    IS_SYNTH               FALSE
    NEEDS_MIDI_INPUT       FALSE
    NEEDS_MIDI_OUTPUT      FALSE
    EDITOR_WANTS_KEYBOARD_FOCUS TRUE
)

target_sources(__PLUGIN_NAME__
    PRIVATE
        Source/PluginProcessor.cpp
        Source/PluginEditor.cpp
        Source/FaustDSP.h
)

target_compile_definitions(__PLUGIN_NAME__
    PUBLIC
        JUCE_WEB_BROWSER=1
        JUCE_USE_CURL=0
        JUCE_VST3_CAN_REPLACE_VST2=0
        JUCE_DISPLAY_SPLASH_SCREEN=0
)

target_link_libraries(__PLUGIN_NAME__
    PRIVATE
        PluginUIData
        juce::juce_audio_utils
        juce::juce_gui_extra
    PUBLIC
        juce::juce_recommended_config_flags
        juce::juce_recommended_lto_flags
        juce::juce_recommended_warning_flags
)
